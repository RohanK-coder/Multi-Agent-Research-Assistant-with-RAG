# Required
GEMINI_API_KEY=your_gemini_api_key_here
# Some libraries/tools look for GOOGLE_API_KEY; keeping both set is convenient.
GOOGLE_API_KEY=your_gemini_api_key_here

# Default cheap student-friendly model
GOOGLE_MODEL=gemini-3.1-flash-lite
GOOGLE_EMBEDDING_MODEL=models/text-embedding-004

# Retrieval settings
RESEARCH_TOP_K=5
CHROMA_DIR=./.chroma
PDF_CHUNK_SIZE=1200
PDF_CHUNK_OVERLAP=150

# Optional better web search
TAVILY_API_KEY=
